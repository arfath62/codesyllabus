# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted (AI Studio / production).
APP_URL="MY_APP_URL"

# SESSION_SECRET: Required in production. Signs auth session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-to-a-long-random-string"

# TOKEN_SECRET: Required in production. Signs progress export/import tokens.
TOKEN_SECRET="change-me-to-another-long-random-string"

# HOST: Server bind address. Use 0.0.0.0 on Railway/Render.
HOST="0.0.0.0"

# PORT: Server port (default 3000)
PORT="3000"
